# ==============================================================================
# Enhanced Security .htaccess for includes/ Directory
# ==============================================================================

# Disable directory browsing
Options -Indexes

# Prevent execution of PHP and server-side scripts (but allow HTML includes)
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|php8|phps|phar|jsp|asp|aspx|cgi|pl|py|rb|sh)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Allow HTML files (needed for includes)
# Note: JavaScript files should be in js/ folder, not includes/
<FilesMatch "\.(html|htm)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Allow from all
    </IfModule>
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
</IfModule>
